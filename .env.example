# trio — example environment file.
# Copy to `.env` and fill in only the key(s) for the driver(s) you use.
# `.env` is gitignored and must NEVER be committed.
#
# The default driver is Claude via the `claude` CLI, which uses your existing
# Claude Code authentication — no key required for the default path. Set the
# matching key below only when selecting an alternate backend with TRIO_DRIVER.
#
# NOTE: the alternate backends (gemini/openai/grok) call paid, metered APIs and
# the engines fan out across many calls per wave. See docs/drivers.md for the
# capability matrix and the cost note before switching.

# Driver selection (default: claude). One of: claude | gemini | openai | grok
# TRIO_DRIVER=claude

# Claude / Anthropic (default driver; the claude CLI normally handles auth)
ANTHROPIC_API_KEY=

# Gemini driver
GEMINI_API_KEY=
# GEMINI_MODEL=        # optional model override (default: gemini-2.0-flash)

# OpenAI driver
OPENAI_API_KEY=
# OPENAI_MODEL=        # optional model override (default: gpt-4o)

# Grok (xAI) driver
XAI_API_KEY=
# XAI_MODEL=           # optional model override (default: grok-2-latest)
